<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>Thêm Tour Mới - Quản Lý Tour Du Lịch</title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

            <div class="card mt-3">
                <div class="card-header bg-primary text-white">Thêm Tour Du Lịch Mới</div>
                <div class="card-body">
                    <form action="/tour/them" method="post">
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Tên Tuyến (Điểm đi - Điểm đến)</label>
                                <input type="text" name="TenTour" class="form-control"
                                    placeholder="VD: Hà Nội - Hạ Long" required>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Giá Tour (VNĐ)</label>
                                <input type="number" name="GiaTour" class="form-control" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Thời Gian</label>
                                <input type="text" name="ThoiGian" class="form-control" placeholder="VD: 2 ngày 1 đêm"
                                    required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Link Hình Ảnh (Pinterest, Google...)</label>
                            <input type="text" name="HinhAnh" class="form-control"
                                placeholder="Dán link http://... vào đây">
                            <small class="text-muted">Hệ thống sẽ tự tải hình này về máy bấy bi.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô Tả Chi Tiết</label>
                            <textarea name="MoTa" id="MoTa" class="form-control"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold">LƯU TOUR MỚI</button>
                    </form>
                </div>
            </div>

            <%- include('footer') %>
    </div>

    <%- include('javascript') %>

        <script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
        <script>
            CKEDITOR.replace('MoTa');
        </script>
</body>

</html>