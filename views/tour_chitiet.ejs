<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>
        <%= tour.TenTour %> - 14pm Travel
    </title>
    <style>
        .main-img-box {
            width: 100%;
            height: 400px;
            object-fit: cover;
            border-radius: 12px;
            background-color: #f8f9fa;
        }

        .thumb-btn {
            width: 80px;
            height: 60px;
            object-fit: cover;
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            opacity: 0.6;
            border: 2px solid #ddd;
            border-radius: 6px;
        }

        .thumb-btn:hover,
        .thumb-btn.active {
            opacity: 1;
            border-color: #0d6efd;
            transform: translateY(-2px);
        }

        .tour-price {
            font-size: 1.8rem;
            color: #dc3545;
            font-weight: 800;
        }

        .description-content {
            line-height: 1.8;
            font-size: 1.05rem;
            color: #333;
        }
    </style>
</head>

<body class="bg-light">
    <%- include('navbar') %>

        <div class="container bg-white shadow-sm rounded-4 p-4 mt-4 mb-5">
            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="position-relative mb-3">
                        <% let anhChinh="/images/no-image.jpg" ; if (tour.HinhAnh) { if (Array.isArray(tour.HinhAnh) &&
                            tour.HinhAnh.length> 0) {
                            anhChinh = tour.HinhAnh[0];
                            } else if (typeof tour.HinhAnh === 'string') {
                            anhChinh = tour.HinhAnh;
                            }
                            }
                            %>
                            <img src="<%= anhChinh %>" id="mainImg" class="main-img-box shadow-sm"
                                onerror="this.src='https://placehold.co/600x400?text=Anh+dang+tai...'">
                    </div>

                    <div class="d-flex gap-2 overflow-auto pb-2 justify-content-center">
                        <% if(Array.isArray(tour.HinhAnh) && tour.HinhAnh.length> 0) { %>
                            <% tour.HinhAnh.forEach((img, index)=> { %>
                                <img src="<%= img %>" class="thumb-btn <%= index === 0 ? 'active' : '' %>"
                                    onclick="changeImage('<%= img %>', this)"
                                    onerror="this.src='https://placehold.co/80x60?text=Loi'">
                                <% }) %>
                                    <% } else if (tour.HinhAnh) { %>
                                        <img src="<%= tour.HinhAnh %>" class="thumb-btn active"
                                            onclick="changeImage('<%= tour.HinhAnh %>', this)">
                                        <% } %>
                    </div>
                </div>

                <div class="col-md-6">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-2">
                            <li class="breadcrumb-item"><a href="/tour" class="text-decoration-none text-muted">Tour</a>
                            </li>
                            <li class="breadcrumb-item active fw-bold">
                                <%= tour.MaTour %>
                            </li>
                        </ol>
                    </nav>
                    <h1 class="h2 fw-bold text-dark mb-3">
                        <%= tour.TenTour %>
                    </h1>

                    <div class="d-flex align-items-center mb-4">
                        <div class="d-flex align-items-center mb-4">
                            <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                                <i class="bi bi-star-fill me-1"></i>
                                <%= tour.SoSao || '5.0' %>
                            </span>
                            <span class="text-muted ms-3 fs-6">
                                (<%= tour.DanhGia || 0 %> đánh giá)
                            </span>
                        </div>
                    </div>

                    <div class="p-4 bg-light rounded-4 mb-4 border-start border-danger border-5">
                        <div class="tour-price">
                            <%= tour.GiaTour.toLocaleString('vi-VN') %> VNĐ
                        </div>
                        <div class="text-secondary small mt-1">Giá tốt nhất thị trường</div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6"><i class="bi bi-clock text-primary me-2"></i><strong>Lịch trình:</strong><br>
                            <%= tour.ThoiGian %>
                        </div>
                        <div class="col-6"><i class="bi bi-geo-alt text-primary me-2"></i><strong>Khởi
                                hành:</strong><br>
                            <%= tour.NoiKhoiHanh %>
                        </div>
                        <div class="col-6"><i class="bi bi-calendar3 text-primary me-2"></i><strong>Ngày
                                đi:</strong><br>
                            <%= new Date(tour.NgayKhoiHanh).toLocaleDateString('vi-VN') %>
                        </div>
                        <div class="col-6"><i class="bi bi-people text-primary me-2"></i><strong>Số
                                chỗ:</strong><br><span class="text-success">
                                <%= tour.SoCho %> khách
                            </span></div>
                    </div>

                    <form action="/datve/them/<%= tour._id %>" method="POST">
                        <button type="submit" class="btn btn-primary w-100">Xác nhận đặt vé</button>
                    </form>
                </div>
            </div>

            <hr class="my-5 opacity-25">

            <div class="row px-4">
                <h3 class="fw-bold mb-4">Chi tiết hành trình</h3>
                <div class="description-content">
                    <%- tour.MoTa %>
                </div>
            </div>

            <hr class="my-5 opacity-25">
            <hr class="my-5 opacity-25">
            <div class="row px-4 mb-5">
                <h4 class="fw-bold mb-4 border-bottom pb-2">Các đánh giá gần đây</h4>

                <% if (typeof danhgias !=='undefined' && danhgias.length> 0) { %>
                    <div class="d-flex flex-column gap-3">
                        <% danhgias.forEach(function(dg) { %>
                            <div class="card border-0 shadow-sm rounded-4 bg-light p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold text-primary mb-0">
                                        <i class="bi bi-person-circle me-2"></i>
                                        <%= dg.NguoiDanhGia %>
                                    </h6>
                                    <small class="text-muted">
                                        <%= new Date(dg.NgayDanhGia).toLocaleDateString('vi-VN') %>
                                    </small>
                                </div>
                                <div class="mb-2 text-warning">
                                    <% for(let i=0; i < dg.DiemSo; i++) { %> <i class="bi bi-star-fill"></i>
                                        <% } %>
                                </div>
                                <p class="mb-0 text-dark">
                                    <%= dg.NoiDung %>
                                </p>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <div class="alert alert-secondary text-center rounded-4">
                            Chưa có đánh giá nào.
                        </div>
                        <% } %>
            </div>
            <div class="row px-4">
                <h4 class="fw-bold mb-4">Đánh giá khách hàng</h4>
                <% if (session && session.User) { %>
                    <form action="/tour/danhgia/<%= tour._id %>" method="POST"
                        class="card p-4 border-0 bg-light rounded-4 shadow-sm">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số sao</label>
                            <select name="DiemSo" class="form-select w-25">
                                <option value="5">5 ⭐</option>
                                <option value="4">4 ⭐</option>
                                <option value="3">3 ⭐</option>
                                <option value="2">2 ⭐</option>
                                <option value="1">1 ⭐</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <textarea name="NoiDung" class="form-control" rows="3"
                                placeholder="Cảm nghĩ của bấy bi về tour này..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary px-4 fw-bold rounded-pill">Gửi đánh giá</button>
                    </form>
                    <% } else { %>
                        <div class="alert alert-warning rounded-4 shadow-sm border-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Vui lòng <a href="/auth/dangnhap" class="fw-bold text-decoration-none">đăng nhập</a> để để
                            lại đánh giá của bạn.
                        </div>
                        <% } %>
            </div>
        </div>

        <%- include('footer') %>
            <%- include('javascript') %>


                <script>
                    function changeImage(src, element) {
                        document.getElementById('mainImg').src = src;
                        document.querySelectorAll('.thumb-btn').forEach(t => t.classList.remove('active'));
                        element.classList.add('active');
                    }
                </script>
</body>

</html>