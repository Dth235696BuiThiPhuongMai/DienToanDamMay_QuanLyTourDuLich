<!DOCTYPE html>
<html lang="vi">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />

	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

	<title><%= title %> - Quản lý Tour</title>
</head>

<body>
	<div class="container">

		<!-- Navbar -->
		<%- include('navbar') %>

		<!-- Nội dung -->
		<div class="card mt-3">
			<div class="card-header">
				📋 <%= title %>
			</div>

			<div class="card-body">

				<a href="/tour/them" class="btn btn-success mb-3">
					<i class="bi bi-plus-circle"></i> Thêm tour
				</a>

				<table class="table table-bordered table-hover text-center align-middle">
					<thead class="table-dark">
						<tr>
							<th>Tên tour</th>
							<th width="220">Hành động</th>
						</tr>
					</thead>

					<tbody>
						<% if (!tours || tours.length === 0) { %>
							<tr>
								<td colspan="2" class="text-muted">
									Chưa có tour nào
								</td>
							</tr>
						<% } else { %>
							<% tours.forEach(t => { %>
								<tr>
									<td class="text-start"><%= t.TenTour %></td>
									<td>
										<a href="/tour/sua/<%= t._id %>" class="btn btn-warning btn-sm">
											<i class="bi bi-pencil"></i> Sửa
										</a>

										<a href="/tour/xoa/<%= t._id %>" 
										   class="btn btn-danger btn-sm"
										   onclick="return confirm('Bạn có chắc muốn xóa không?')">
											<i class="bi bi-trash"></i> Xóa
										</a>
									</td>
								</tr>
							<% }) %>
						<% } %>
					</tbody>
				</table>

			</div>
		</div>

		<!-- Footer -->
		<%- include('footer') %>
	</div>

	<%- include('javascript') %>
</body>

</html>