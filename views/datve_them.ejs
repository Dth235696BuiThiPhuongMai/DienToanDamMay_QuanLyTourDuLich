<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>Đặt Vé - <%= tour.TenTour %>
    </title>
</head>

<body>
    <div class="container">
        <%- include('navbar') %>

            <div class="card mt-4 mx-auto" style="max-width: 600px; border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-success text-white text-center py-3">
                    <h5 class="mb-0"><i class="bi bi-wallet2 me-2"></i>XÁC NHẬN ĐẶT VÉ & THANH TOÁN</h5>
                </div>

                <div class="card-body p-4">
                    <h6 class="text-primary mb-2">Tour đã chọn:</h6>
                    <h5 class="fw-bold mb-3">
                        <%= tour.TenTour %>
                    </h5>

                    <div class="p-3 bg-light rounded mb-4">
                        <p class="mb-1 text-muted">Đơn giá niêm yết:</p>
                        <h5 class="text-danger fw-bold mb-0">
                            <span id="giaGocHienThi">
                                <%= tour.GiaTour.toLocaleString() %>
                            </span> VNĐ / người
                        </h5>
                    </div>

                    <hr>

                    <form action="/datve/them/<%= tour._id %>" method="POST" class="needs-validation">
                        <div class="mb-3">
                            <label for="HoTen" class="form-label fw-bold">Họ và tên người đặt</label>
                            <input type="text" class="form-control" id="HoTen" name="HoTen"
                                value="<%= session.User ? session.User.HoVaTen : '' %>"
                                placeholder="Nhập họ tên của bạn" required />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="DienThoai" class="form-label fw-bold">Số điện thoại</label>
                                <input type="text" class="form-control" id="DienThoai" name="DienThoai"
                                    placeholder="VD: 0901234567" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="SoNguoi" class="form-label fw-bold">Số lượng người</label>
                                <input type="number" class="form-control fw-bold text-center" id="soNguoi"
                                    name="SoNguoi" min="1" value="1" oninput="tinhTien()" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="GhiChu" class="form-label fw-bold">Ghi chú thêm</label>
                            <textarea class="form-control" name="GhiChu" rows="2"
                                placeholder="Yêu cầu đặc biệt nếu có..."></textarea>
                        </div>

                        <div class="alert alert-warning border-0 shadow-sm mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-dark">TỔNG TIỀN:</span>
                                <h4 class="mb-0 fw-bolder text-danger">
                                    <span id="hienTongTien">
                                        <%= tour.GiaTour.toLocaleString() %>
                                    </span> VNĐ
                                </h4>
                            </div>
                            <input type="hidden" name="TongTien" id="tongTienInput" value="<%= tour.GiaTour %>">
                        </div>

                        <button type="button" class="btn btn-success btn-lg w-100 fw-bold shadow-sm"
                            onclick="showPreview()">
                            <i class="bi bi-cart-plus me-2"></i>TIẾN HÀNH ĐẶT VÉ
                        </button>

                        <div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header bg-primary text-white">
                                        <h5 class="modal-title">Xác nhận thông tin đặt tour</h5>
                                        <button type="button" class="btn-close btn-close-white"
                                            data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body fs-6">
                                        <p>Tour: <strong class="text-primary">
                                                <%= tour.TenTour %>
                                            </strong></p>
                                        <p>Người đặt: <strong id="preHoTen"></strong></p>
                                        <p>Số người: <strong id="preSoNguoi"></strong></p>
                                        <hr>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="fs-5">Tổng thanh toán:</span>
                                            <span class="fs-4 fw-bold text-danger" id="preTongTien"></span>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Quay
                                            lại</button>
                                        <button type="submit" class="btn btn-success fw-bold">THANH TOÁN NGAY</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <%- include('footer') %>
    </div>
    <%- include('javascript') %>

        <script>
            // Hàm tính tiền tự động
            function tinhTien() {
                const gia = Number('<%= tour.GiaTour %>') || 0;
                let soNguoi = document.getElementById('soNguoi').value;
                if (soNguoi < 1 || soNguoi === "") soNguoi = 1;
                const tong = gia * soNguoi;
                document.getElementById('hienTongTien').innerText = tong.toLocaleString('vi-VN');
                document.getElementById('tongTienInput').value = tong;
            }

            // Hàm hiện Modal xem trước thông tin
            function showPreview() {
                // Lấy dữ liệu từ form
                const hoTen = document.getElementById('HoTen').value;
                const soNguoi = document.getElementById('soNguoi').value;
                const tongTien = document.getElementById('hienTongTien').innerText;

                if (!hoTen || !document.getElementById('DienThoai').value) {
                    alert("Bấy bi nhập đầy đủ thông tin liên lạc đã nhé!");
                    return;
                }

                // Gán vào Modal
                document.getElementById('preHoTen').innerText = hoTen;
                document.getElementById('preSoNguoi').innerText = soNguoi + " khách";
                document.getElementById('preTongTien').innerText = tongTien + " VNĐ";

                // Hiện Modal
                var myModal = new bootstrap.Modal(document.getElementById('previewModal'));
                myModal.show();
            }

            window.onload = tinhTien;
        </script>
</body>

</html>