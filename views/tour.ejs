<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <title>Danh Sách Tour - 14pm Travel</title>
    <style>
        .tour-img {
            width: 80px;
            height: 50px;
            object-fit: cover;
            border-radius: 4px;
        }

        .table-middle td,
        .table-middle th {
            vertical-align: middle;
            font-size: 0.9rem;
        }

        .sidebar-title {
            border-left: 4px solid #0d6efd;
            padding-left: 10px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .fav-tour-item {
            transition: all 0.3s;
            border: none;
            border-bottom: 1px solid #eee;
            text-decoration: none;
            display: block;
        }

        .fav-tour-item:hover {
            background-color: #f8f9fa;
        }

        .badge-price {
            background-color: #fff5f5;
            color: #e03131;
            border: 1px solid #ffa8a8;
        }

        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .tour-img {
            aspect-ratio: 16/9;
            /* Giữ tỉ lệ khung hình chuẩn */
            border: 1px solid #ddd;
        }


        .table-hover tbody tr:hover {
            background-color: #f1f7ff !important;
            transition: 0.2s;
        }


        .badge-price {
            padding: 0.4em 0.8em;
            border-radius: 50px;
            /* Bo tròn hẳn nhìn sẽ sang hơn */
            font-weight: 600;
        }

        .btn-outline-primary {
            white-space: nowrap;
        }
    </style>
</head>

<body>
    <div class="container mt-4">
        <%- include('navbar') %>

            <div class="row mt-4">
                <div class="col-lg-9">
                    <div class="card shadow-sm border-0">
                        <div
                            class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-grid-3x3-gap-fill me-2"></i>TẤT CẢ CÁC TOUR</h5>
                            <% if (typeof session !=='undefined' && session.Role==='admin' ) { %>
                                <a href="/tour/them" class="btn btn-light btn-sm fw-bold"><i
                                        class="bi bi-plus-circle"></i> Thêm</a>
                                <% } %>
                        </div>

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted small">Tìm thấy <strong>
                                        <%= tours.length %>
                                    </strong> tour</span>
                                <div class="dropdown">
                                    <button class="btn btn-white border dropdown-toggle btn-sm fw-bold shadow-sm"
                                        type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-sort-down text-primary"></i> Sắp xếp theo
                                    </button>
                                    <ul class="dropdown-menu shadow border-0">
                                        <% let sVal=(typeof currentSort !=='undefined' ) ? currentSort : '' ; %>
                                            <li><a class="dropdown-item <%= sVal === 'price_asc' ? 'active' : '' %>"
                                                    href="?page=1&sort=price_asc">Giá tăng dần</a></li>
                                            <li><a class="dropdown-item <%= sVal === 'price_desc' ? 'active' : '' %>"
                                                    href="?page=1&sort=price_desc">Giá giảm dần</a></li>
                                            <li><a class="dropdown-item <%= sVal === 'popular' ? 'active' : '' %>"
                                                    href="?page=1&sort=popular">Đánh giá cao nhất</a></li>
                                    </ul>
                                </div>
                            </div>

                            <div class="table-responsive">
                                <table class="table table-hover table-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Tour</th>
                                            <th class="text-center">Giá</th>
                                            <th class="text-center">Thời gian</th>
                                            <th class="text-end">Thao tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% tours.forEach((item)=> { %>
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <img src="<%= Array.isArray(item.HinhAnh) ? item.HinhAnh[0] : item.HinhAnh %>"
                                                            class="tour-img me-3">
                                                        <div>
                                                            <a href="/tours/chitiet/<%= item._id %>"
                                                                class="text-decoration-none fw-bold text-dark d-block text-truncate"
                                                                style="max-width: 250px;">
                                                                <%= item.TenTour %>
                                                            </a>
                                                            <small class="text-muted">
                                                                <%= item.MaTour %>
                                                            </small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center text-danger fw-bold">
                                                    <%= item.GiaTour.toLocaleString('vi-VN') %>đ
                                                </td>
                                                <td class="text-center small text-muted">
                                                    <%= item.ThoiGian %>
                                                </td>
                                                <td class="text-end">
                                                    <a href="/tours/chitiet/<%= item._id %>"
                                                        class="btn btn-sm btn-outline-primary"><i
                                                            class="bi bi-eye"></i></a>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>

                            <% if (typeof totalPages !=='undefined' ) { %>
                                <nav class="mt-4">
                                    <ul class="pagination pagination-sm justify-content-center">
                                        <% for(let i=1; i <=totalPages; i++) { %>
                                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                <a class="page-link"
                                                    href="?page=<%= i %><%= sVal ? '&sort=' + sVal : '' %>">
                                                    <%= i %>
                                                </a>
                                            </li>
                                            <% } %>
                                    </ul>
                                </nav>
                                <% } %>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3">
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body">
                            <h6 class="sidebar-title text-uppercase">Tour được yêu thích nhất</h6>
                            <div class="list-group list-group-flush">
                                <% if (typeof favTours !=='undefined' && favTours.length> 0) { %>
                                    <% favTours.forEach(fav=> { %>
                                        <a href="/tour/chitiet/<%= fav._id %>"
                                            class="list-group-item fav-tour-item px-0 py-3">
                                            <div class="row g-0 align-items-center">
                                                <div class="col-4">
                                                    <img src="<%= Array.isArray(fav.HinhAnh) ? fav.HinhAnh[0] : fav.HinhAnh %>"
                                                        class="img-fluid rounded shadow-sm">
                                                </div>
                                                <div class="col-8 ps-2">
                                                    <span class="fw-bold small d-block text-truncate-2 text-dark"
                                                        style="line-height: 1.2;">
                                                        <%= fav.TenTour %>
                                                    </span>
                                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                                        <small class="text-warning" style="font-size: 0.75rem;">
                                                            <i class="bi bi-star-fill"></i>
                                                            <%= fav.DanhGia || '5.0' %>
                                                        </small>
                                                        <span class="badge badge-price" style="font-size: 0.7rem;">
                                                            <%= fav.GiaTour.toLocaleString('vi-VN') %>đ
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </a>
                                        <% }) %>
                                            <% } else { %>
                                                <p class="small text-muted text-center">Đang cập nhật...</p>
                                                <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <h6 class="sidebar-title text-uppercase">Hỗ trợ khách hàng</h6>
                            <p class="small text-muted mb-1"><i class="bi bi-telephone-fill me-2 text-primary"></i>
                                0383793431</p>
                            <p class="small text-muted mb-0"><i class="bi bi-envelope-fill me-2 text-primary"></i>
                                phuongmaiza@.com</p>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('footer') %>
    </div>
    <%- include('javascript') %>
</body>

</html>