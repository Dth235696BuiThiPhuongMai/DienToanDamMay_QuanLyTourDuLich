<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="/css/app.css" rel="stylesheet" />

    <style>
        /* Tùy chỉnh thêm cho thẻ Tour */
        .tour-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: none;
            border-radius: 15px;
            overflow: hidden;
        }

        .tour-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
        }

        .tour-img-container {
            position: relative;
            height: 220px;
            overflow: hidden;
        }

        .tour-img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .tour-card:hover .tour-img-container img {
            transform: scale(1.1);
        }

        .price-tag {
            color: #ff4d4d;
            font-weight: bold;
            font-size: 1.25rem;
        }

        .badge-destination {
            position: absolute;
            top: 15px;
            left: 15px;
            background-color: rgba(13, 110, 253, 0.85);
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100 bg-light">

    <%- include('navbar') %>

        <div class="bg-primary text-white py-5 mb-5 shadow-sm"
            style="background: linear-gradient(45deg, #0d6efd, #0099ff);">
            <div class="container py-4 text-center">
                <h1 class="display-4 fw-bold">Escape the ordinary</h1>
                <p class="lead">"Khám phá địa điểm độc đáo và không giới hạn cùng chúng tôi"</p>
            </div>
        </div>

        <main class="main flex-grow-1">
            <div class="container">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold mb-0 text-dark"><i class="bi bi-fire text-danger"></i> Tour mới nhất</h2>
                    <a href="/tours" class="text-decoration-none fw-bold">Xem tất cả &rarr;</a>
                </div>

                <div class="row g-4">
                    <% if(tours && tours.length> 0) { %>
                        <% tours.forEach(tour=> { %>

                            <div class="col-lg-4 col-md-6">
                                <div class="card h-100 shadow-sm tour-card">
                                    <div class="tour-img-container">
                                        <img src="<%= (tour.HinhAnh && Array.isArray(tour.HinhAnh)) ? tour.HinhAnh[0] : tour.HinhAnh %>"
                                            class="card-img-top" onerror="this.src='/images/no-image.jpg'">
                                        <span class="badge-destination"><i class="bi bi-geo-alt-fill"></i>
                                            <%= tour.DiemDen %>
                                        </span>
                                    </div>
                                    <div class="card-body p-4">
                                        <h5 class="card-title fw-bold text-dark mb-2 text-truncate-2"
                                            style="height: 3rem; overflow: hidden;">
                                            <%= tour.TenTour %>
                                        </h5>
                                        <div
                                            class="d-flex justify-content-between align-items-center mb-3 text-muted small">
                                            <span><i class="bi bi-clock me-1"></i>
                                                <%= tour.ThoiGian %>
                                            </span>
                                            <span><i class="bi bi-calendar-event me-1"></i>
                                                <%= tour.NgayKhoiHanh %>
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center mt-auto">
                                            <div class="price-tag">
                                                <%= tour.GiaTour.toLocaleString('vi-VN') %> <small>đ</small>
                                            </div>
                                            <a href="/tours/chitiet/<%= tour._id %>"
                                                class="btn btn-outline-primary rounded-pill px-4">Chi tiết</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="col-12 text-center py-5">
                                        <i class="bi bi-inbox fs-1 text-muted"></i>
                                        <p class="mt-3 text-muted">Hiện chưa có tour nào được đăng. Quay lại sau nhé!
                                        </p>
                                    </div>
                                    <% } %>
                </div>

                <nav class="my-5">
                    <ul class="pagination justify-content-center border-0">

                        <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                            <a class="page-link border-0 shadow-sm mx-1 rounded text-dark"
                                href="<%= currentPage <= 1 ? '#' : '?page=' + (currentPage - 1) %>">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        <% for(let i=1; i <=totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link border-0 shadow-sm mx-1 rounded <%= currentPage !== i ? 'text-dark' : '' %>"
                                    href="?page=<%= i %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } %>

                                <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                    <a class="page-link border-0 shadow-sm mx-1 rounded text-dark"
                                        href="<%= currentPage >= totalPages ? '#' : '?page=' + (currentPage + 1) %>">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>

                    </ul>
                </nav>
            </div>
        </main>

        <%- include('footer') %>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>