<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <title>Sửa Tour - <%= tour.TenTour %></title>
</head>
<body>
    <div class="container">
        <%- include('navbar') %>
        <div class="card mt-3">
            <div class="card-header bg-warning">Cập Nhật Thông Tin Tour</div>
            <div class="card-body">
                <form action="/tour/sua/<%= tour._id %>" method="post">
                    <div class="mb-3">
                        <label for="TenTour" class="form-label">Tên chuyến đi</label>
                        <input type="text" class="form-control" id="TenTour" name="TenTour" value="<%= tour.TenTour %>" required />
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="GiaTour" class="form-label">Giá Tour</label>
                            <input type="number" class="form-control" id="GiaTour" name="GiaTour" value="<%= tour.GiaTour %>" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="ThoiGian" class="form-label">Thời gian</label>
                            <input type="text" class="form-control" id="ThoiGian" name="ThoiGian" value="<%= tour.ThoiGian %>" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label for="HinhAnh" class="form-label">URL Hình ảnh</label>
                            <input type="text" class="form-control" id="HinhAnh" name="HinhAnh" value="<%= tour.HinhAnh[0] %>" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="MoTa" class="form-label">Chương trình chi tiết</label>
                        <textarea class="form-control" id="MoTa" name="MoTa" rows="5"><%= tour.MoTa %></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Cập nhật thay đổi</button>
                    <a href="/tour" class="btn btn-secondary">Quay lại</a>
                </form>
            </div>
        </div>
        <%- include('footer') %>
    </div>
    <%- include('javascript') %>
    <script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
    <script>CKEDITOR.replace('MoTa');</script>
</body>
</html>